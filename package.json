{
  "name": "ai-chatbot",
  "version": "0.0.1",
  "description": "AI chatbot backend API",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "generate:api": "ts-node scripts/generate-api.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.4",
    "@nestjs/core": "^10.3.4",
    "@nestjs/platform-express": "^10.3.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.4",
    "@nestjs/schematics": "^10.0.4",
    "@nestjs/testing": "^10.3.4",
    "@types/node": "^20.14.4",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
